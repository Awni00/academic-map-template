{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "types": ["astro/client", "node"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "astro.config.ts",
    "src/**/*",
    "scripts/**/*",
    "tests/**/*"
  ],
  "exclude": ["dist", "node_modules"]
}
