---
import { highlightedAuthorParts, publicationLinks } from "../../lib/publications/formatPublication";
import type { Publication } from "../../lib/publications/types";

type Props = {
  publication: Publication;
  compact?: boolean;
};

const { publication, compact = false } = Astro.props;
const links = publicationLinks(publication);
const authorParts = highlightedAuthorParts(publication.author);
const thumbHref =
  publication.pdf ?? publication.url ?? publication.website ?? undefined;
---

<article class:list={["publication-item", compact && "publication-item--compact"]}>
  {!compact && (
    thumbHref ? (
      <a href={thumbHref} class="publication-preview" aria-hidden="true">
        {publication.preview ? (
          <img src={publication.preview} alt="" loading="lazy" />
        ) : (
          <div class="publication-thumb-fallback" />
        )}
        {publication.abbr && <span class="publication-thumb-tag">{publication.abbr}</span>}
      </a>
    ) : (
      <div class="publication-preview" aria-hidden="true">
        {publication.preview ? (
          <img src={publication.preview} alt="" loading="lazy" />
        ) : (
          <div class="publication-thumb-fallback" />
        )}
        {publication.abbr && <span class="publication-thumb-tag">{publication.abbr}</span>}
      </div>
    )
  )}
  <div class="publication-body">
    <h3>{publication.title}</h3>
    <p class="publication-authors">
      {
        authorParts.map((part) =>
          part.highlighted ? <strong>{part.text}</strong> : <span>{part.text}</span>
        )
      }
    </p>
    <div class="publication-meta">
      <span class="publication-venue">
        {publication.venue ? <i>{publication.venue}</i> : publication.type}, {publication.year}
      </span>
      <div class="publication-links">
        {links.map((link) => <a class="publication-link" href={link.href}>{link.label}</a>)}
        {
          publication.bibtexShow && (
            <details class="publication-bibtex">
              <summary>BibTeX</summary>
              <pre><code>{publication.raw}</code></pre>
            </details>
          )
        }
      </div>
    </div>
    {publication.abstract && !compact && <p class="muted" style="margin-top: 8px; font-size: 13.5px; line-height: 1.5;">{publication.abstract}</p>}
  </div>
</article>
