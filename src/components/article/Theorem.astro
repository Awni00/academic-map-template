---
type Props = {
  /** Display name, e.g. "Theorem 1" or "Definition". Defaults to "Theorem". */
  name?: string;
  /** Optional descriptive title shown in parentheses next to the name. */
  title?: string;
  /** Anchor id for in-document links. */
  label?: string;
  /** Switches to "definition" presentation (neutral label, upright body). */
  kind?: "theorem" | "definition";
};

const { name, title, label, kind = "theorem" } = Astro.props;
const displayName = name ?? (kind === "definition" ? "Definition" : "Theorem");
const classes = ["theorem", kind === "definition" && "theorem--def"].filter(Boolean).join(" ");
---

<section class={classes} id={label}>
  <div class="theorem-head">
    <span class="theorem-name">{displayName}</span>
    {title && <span class="theorem-title">({title})</span>}
  </div>
  <div class="theorem-body">
    <slot />
  </div>
</section>
