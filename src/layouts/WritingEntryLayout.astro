---
import Aside from "../components/article/Aside.astro";
import BibtexBlock from "../components/article/BibtexBlock.astro";
import Callout from "../components/article/Callout.astro";
import Comparison from "../components/article/Comparison";
import EntryFooter from "../components/article/EntryFooter.astro";
import Figure from "../components/article/Figure.astro";
import MathBlock from "../components/article/MathBlock.astro";
import ModelViewer from "../components/article/ModelViewer.astro";
import Picture from "../components/article/Picture.astro";
import Proof from "../components/article/Proof.astro";
import TableOfContents from "../components/article/TableOfContents";
import Theorem from "../components/article/Theorem.astro";
import TwoColumns from "../components/article/TwoColumns.astro";
import Video from "../components/article/Video.astro";
import YouTubeVideo from "../components/article/YouTubeVideo.astro";
import LocalGraph from "../components/graph/LocalGraph";
import { entryToRecord } from "../lib/graph/resolveLinks";
import {
  effectiveAsides,
  resolveArticleWidth,
  resolveAsides,
  resolvePlacement
} from "../lib/article/placement";
import type { GraphIndex, WritingEntryLike } from "../lib/graph/types";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  entry: WritingEntryLike;
  graph: GraphIndex;
  headings: Array<{ depth: number; slug: string; text: string }>;
  Content: any;
};

const { entry, graph, headings, Content } = Astro.props;
const record = entryToRecord(entry);
const node = record.node;
const byId = new Map(graph.nodes.map((item) => [item.id, item]));

const articleWidth = resolveArticleWidth(entry);
const placement = resolvePlacement(entry);
const asidesRequested = resolveAsides(entry);
const asidesEffective = effectiveAsides(asidesRequested, articleWidth, placement.toc.where);

const outgoing = graph.outgoing[node.id] ?? [];
const backlinkIds = graph.backlinks[node.id] ?? [];
const relatedIds = [...new Set([...outgoing, ...backlinkIds])].slice(0, 6);
const toLinkedItem = (id: string) => {
  const item = byId.get(id);
  return item ? { id, title: item.title, url: item.url } : null;
};
const backlinks = backlinkIds.map(toLinkedItem).filter(Boolean) as Array<{ id: string; title: string; url: string }>;
const related = relatedIds.map(toLinkedItem).filter(Boolean) as Array<{ id: string; title: string; url: string }>;
const external = Object.entries(entry.data.external ?? {}).filter(([, href]) => Boolean(href));

// Slot derivation. The TOC lives in either the left or right grid
// column; backlinks/related can also live there if explicitly placed.
const tocSide: "left" | "right" | "none" =
  placement.toc.where === "none" ? "none" : placement.toc.where;
const backlinksSide = placement.backlinks.where;
const relatedSide = placement.related.where;
const localGraphInHeader = placement.localGraph.where === "header";
const localGraphInFooter = placement.localGraph.where === "footer";
const backlinksInFooter = backlinksSide === "footer";
const relatedInFooter = relatedSide === "footer";

const sideHasContent = (side: "left" | "right"): boolean =>
  (tocSide === side && headings.length > 0) ||
  (backlinksSide === side && backlinks.length > 0) ||
  (relatedSide === side && related.length > 0);

const renderLeft = sideHasContent("left");
const renderRight = sideHasContent("right");

const renderFooter =
  localGraphInFooter || backlinksInFooter || relatedInFooter;

const components = {
  Aside,
  BibtexBlock,
  Callout,
  Comparison,
  Figure,
  MathBlock,
  ModelViewer,
  Picture,
  Proof,
  Theorem,
  TwoColumns,
  Video,
  YouTubeVideo
};

const renderSide = (side: "left" | "right") => ({
  toc: tocSide === side && headings.length > 0,
  backlinks: backlinksSide === side && backlinks.length > 0,
  related: relatedSide === side && related.length > 0
});
const left = renderSide("left");
const right = renderSide("right");
---

<BaseLayout title={node.title} description={node.summary} theme={entry.data.theme}>
  <article class="writing-shell">
    <div
      class="article-grid"
      data-width={articleWidth}
      data-toc={tocSide}
      data-asides={asidesEffective}
      data-has-left={renderLeft ? "true" : "false"}
      data-has-right={renderRight ? "true" : "false"}
      data-has-foot={renderFooter ? "true" : undefined}
    >
      <header class="article-header">
        <h1>{node.title}</h1>
        <div class="article-meta">
          <span>{node.type}</span>
          {node.date && <span>{node.date}</span>}
          {node.tags.map((tag) => <span>{tag}</span>)}
        </div>
        {node.summary && <p class="article-summary">{node.summary}</p>}
        {
          external.length > 0 && (
            <div class="article-external">
              {external.map(([label, href]) => <a class="entry-chip" href={href as string}>{label}</a>)}
            </div>
          )
        }
        {
          localGraphInHeader && (
            <div class="article-header__graph">
              <LocalGraph client:load graph={graph} currentId={node.id} />
            </div>
          )
        }
      </header>

      {
        renderLeft && (
          <aside class="article-sidebar article-sidebar--left" aria-label="Article sidebar (left)">
            {left.toc && (
              <section class="sidebar-section sidebar-section--toc">
                <h2>On This Page</h2>
                <TableOfContents client:load headings={headings} />
              </section>
            )}
            {left.backlinks && (
              <section class="sidebar-section">
                <h2>Backlinks</h2>
                <ul>
                  {backlinks.map((item) => (
                    <li><a href={item.url}>{item.title}</a></li>
                  ))}
                </ul>
              </section>
            )}
            {left.related && (
              <section class="sidebar-section">
                <h2>Related</h2>
                <ul>
                  {related.map((item) => (
                    <li><a href={item.url}>{item.title}</a></li>
                  ))}
                </ul>
              </section>
            )}
          </aside>
        )
      }

      <main class="article-main">
        <div class="article-content" data-asides={asidesEffective}>
          <Content components={components} />
        </div>
      </main>

      {
        renderRight && (
          <aside class="article-sidebar article-sidebar--right" aria-label="Article sidebar (right)">
            {right.toc && (
              <section class="sidebar-section sidebar-section--toc">
                <h2>On This Page</h2>
                <TableOfContents client:load headings={headings} />
              </section>
            )}
            {right.backlinks && (
              <section class="sidebar-section">
                <h2>Backlinks</h2>
                <ul>
                  {backlinks.map((item) => (
                    <li><a href={item.url}>{item.title}</a></li>
                  ))}
                </ul>
              </section>
            )}
            {right.related && (
              <section class="sidebar-section">
                <h2>Related</h2>
                <ul>
                  {related.map((item) => (
                    <li><a href={item.url}>{item.title}</a></li>
                  ))}
                </ul>
              </section>
            )}
          </aside>
        )
      }
    </div>
    <EntryFooter
      graph={graph}
      currentId={node.id}
      headings={headings}
      tocInFoot={false}
      showLocalGraph={localGraphInFooter}
      backlinks={backlinksInFooter ? backlinks : []}
      related={relatedInFooter ? related : []}
    />
  </article>
</BaseLayout>
