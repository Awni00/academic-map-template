---
import BaseLayout from "./BaseLayout.astro";
import Callout from "../components/article/Callout.astro";
import Figure from "../components/article/Figure.astro";
import MathBlock from "../components/article/MathBlock.astro";
import type { GraphIndex, EntryNode } from "../lib/graph/types";
import type { Publication } from "../lib/publications/types";
import WritingPreview from "../components/graph/WritingPreview";
import PublicationItem from "../components/publications/PublicationItem.astro";
import { siteConfig } from "../config/site";

type NewsItem = {
  date: string;
  title: string;
  url?: string;
};

type Props = {
  graph: GraphIndex;
  recentWriting: EntryNode[];
  selectedPublications: Publication[];
  news: NewsItem[];
  Content: any;
};

const { graph, recentWriting, selectedPublications, news, Content } = Astro.props;
const previewConfig = siteConfig.homepage.writingPreview;
const components = { Callout, Figure, MathBlock };
const showPubs =
  siteConfig.homepage.selectedPublications.enabled && selectedPublications.length > 0;
const showRecent = siteConfig.homepage.recentWriting.enabled && recentWriting.length > 0;
const showNews = siteConfig.homepage.news.enabled && news.length > 0;
const showResearch = siteConfig.homepage.researchSummary.enabled;
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="hero">
    <div class="hero__left">
      <h1 class="h1">{siteConfig.name}</h1>
      <div class="role">
        {siteConfig.role}, {siteConfig.affiliation}
      </div>
      {
        showResearch && (
          <div class="bio">
            <Content components={components} />
          </div>
        )
      }
      <div class="sociallinks">
        {
          [
            { label: "Email", href: siteConfig.links.email },
            { label: "CV", href: siteConfig.links.cv },
            { label: "Scholar", href: siteConfig.links.scholar },
            { label: "GitHub", href: siteConfig.links.github }
          ].map((link, i) => (
            <>
              {i > 0 && <span class="sociallinks-sep">·</span>}
              <a class="sociallinks-link" href={link.href}>{link.label}</a>
            </>
          ))
        }
      </div>
    </div>
    <div class="hero__right">
      <div class="profile-card">
        <img src={siteConfig.profileImage} alt={`${siteConfig.name} profile`} />
      </div>
    </div>
  </section>

  {
    previewConfig.enabled && (
      <section class="section">
        <WritingPreview
          client:load
          graph={graph}
          title={previewConfig.title}
          description={previewConfig.description}
          clickTarget={previewConfig.clickTarget}
          filter={previewConfig.filter as any}
          maxNodes={previewConfig.maxNodes}
          previewHeight={previewConfig.previewHeight}
          desktopMode={previewConfig.desktopMode}
          mobileMode={previewConfig.mobileMode}
        />
      </section>
    )
  }

  {
    (showPubs || showNews) && (
      <section class="section">
        <div class="cols2">
          {showPubs && (
            <section>
              <h2 class="h2">Selected publications</h2>
              <div class="publication-list">
                {selectedPublications.map((publication) => (
                  <PublicationItem publication={publication} />
                ))}
              </div>
              <a class="cta" href="/publications">All publications →</a>
            </section>
          )}
          {showNews && (
            <aside>
              <h2 class="h2">News</h2>
              <dl class="news">
                {news.map((item) => (
                  <>
                    <dt>{item.date}</dt>
                    <dd>
                      {item.url ? <a href={item.url}>{item.title}</a> : <span>{item.title}</span>}
                    </dd>
                  </>
                ))}
              </dl>
            </aside>
          )}
        </div>
      </section>
    )
  }

  {
    showRecent && (
      <section class="section">
        <div class="sect-head">
          <h2 class="h2">Recent writing</h2>
          <a class="cta cta--small" href="/writing">All →</a>
        </div>
        <ul class="recent">
          {recentWriting.map((entry) => (
            <li class="recent-card">
              <div class="recent-meta">
                <span class={`pill pill--${entry.type}`}>{entry.type}</span>
                <span class="recent-date">{entry.date}</span>
              </div>
              <a class="recent-title" href={entry.url} style="text-decoration: none; color: inherit; display: block;">
                {entry.title}
              </a>
              {entry.summary && <div class="recent-summary">{entry.summary}</div>}
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
